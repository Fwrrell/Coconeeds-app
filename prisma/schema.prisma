// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PETANI
  PERUSAHAAN
  ADMIN
}

model User {
  id            String    @id @default(uuid())
  name          String?
  phoneNumber   String?   @unique
  pin           String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(PETANI)
  location      String?
  ecoPoints     Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  panens   Panen[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

enum PengirimanMethod {
  SELF_DELIVERY
  PICKUP
}

enum PanenStatus {
  PENDING_PICKUP
  PENDING_DROPOFF
  IN_WAREHOUSE
  IN_TRANSIT
  DELIVERED
}

model Panen {
  id               String           @id @default(uuid())
  petaniId         String
  petani           User             @relation(fields: [petaniId], references: [id], onDelete: Cascade)
  type             String // KOPRA | SABUT | TEMPURUNG
  expectedWeight   Float // estimasi berat (input petani)
  tanggalPanen     DateTime
  pengirimanMethod PengirimanMethod
  actualWeight     Float? // berat actual dari qc
  grade            String?
  moisture         Float?
  basePricePerKg   Float?
  profitMargin     Float?
  status           PanenStatus      @default(PENDING_PICKUP)
  createdAt        DateTime         @default(now())
  updateAt         DateTime         @updatedAt
  batchId          String?

  batch Batch? @relation(fields: [batchId], references: [id])
}

model Batch {
  id          String      @id @default(uuid())
  type        String
  totalWeight Float
  status      PanenStatus @default(IN_WAREHOUSE)
  createdAt   DateTime    @default(now())
  updateAt    DateTime    @updatedAt
  panens      Panen[]
  ledger      Ledger?
}

model Ledger {
  id          String   @id @default(ulid())
  batchId     String   @unique
  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  prevHash    String // Hash dari batch sebelumnya
  currentHash String // Hash gabungan dari data batch + data qc
  createdAt   DateTime @default(now())
}
