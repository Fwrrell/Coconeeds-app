// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PETANI
  PERUSAHAAN
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  phoneNumber   String?   @unique
  pin           String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(PETANI)
  kopdesId      String?
  kopdes        Kopdes?   @relation(fields: [kopdesId], references: [id])
  ecoPoints     Int       @default(0)
  isVerified    Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  accounts Account[]
  panens      Panen[]
  wtbListings WtbListing[]
}

model Kopdes {
  id        String   @id @default(uuid())
  name      String
  region    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model SystemSetting {
  id                String   @id @default("global_config")
  autoVerifyNewUser Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

enum PengirimanMethod {
  SELF_DELIVERY
  PICKUP
}

enum PanenStatus {
  PENDING_PICKUP
  PENDING_DROPOFF
  IN_WAREHOUSE
  IN_TRANSIT
  DELIVERED
}

model Panen {
  id               String           @id @default(uuid())
  petaniId         String
  petani           User             @relation(fields: [petaniId], references: [id], onDelete: Cascade)
  type             String // KOPRA | SABUT | TEMPURUNG
  expectedWeight   Float // estimasi berat (input petani)
  tanggalPanen     DateTime
  pengirimanMethod PengirimanMethod
  actualWeight     Float? // berat actual dari qc
  grade            String?
  moisture         Float?
  basePricePerKg   Float?
  profitMargin     Float?
  status           PanenStatus      @default(PENDING_PICKUP)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  batchId          String?

  batch Batch? @relation(fields: [batchId], references: [id])
}

model Batch {
  id                String           @id @default(uuid())
  pengirimanKapalId String?
  pengirimanKapal   PengirimanKapal? @relation(fields: [pengirimanKapalId], references: [id])
  type              String
  totalWeight       Float
  status            PanenStatus      @default(IN_WAREHOUSE)
  wtbListingId      String?
  wtbListing        WtbListing?      @relation(fields: [wtbListingId], references: [id], onDelete: Cascade)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  panens Panen[]
  ledger Ledger?
}

model Ledger {
  id          String   @id @default(ulid())
  batchId     String   @unique
  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  prevHash    String // Hash dari batch sebelumnya
  currentHash String // Hash gabungan dari data batch + data qc
  createdAt   DateTime @default(now())
}

enum WtbStatus {
  OPEN
  DEAL
  COMPLETED
}

model WtbListing {
  id           String    @id @default(uuid())
  perusahaanId String
  perusahaan   User      @relation(fields: [perusahaanId], references: [id], onDelete: Cascade)
  komoditas    String // e.g.: KOPRA | SABUT | ...
  targetWeight Float
  maxPrice     Float
  destination  String
  status       WtbStatus @default(OPEN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  negosiasi Negosiasi[]
  batches   Batch[]
}

model Negosiasi {
  id           String     @id @default(uuid())
  wtbId        String
  wtb          WtbListing @relation(fields: [wtbId], references: [id], onDelete: Cascade)
  senderRole   Role
  offeredPrice Float
  note         String?
  createdAt    DateTime   @default(now())
}

enum PengirimanKapalStatus {
  WAITING_DEPARTURE
  IN_TRANSIT
  ARRIVED
}

model PengirimanKapal {
  id          String                @id @default(uuid())
  namaKapal   String
  rute        String
  totalBiaya  Float
  totalWeight Float
  status      PengirimanKapalStatus @default(WAITING_DEPARTURE)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  batches    Batch[]
  splitBills SplitBill[]
}

model SplitBill {
  id                String          @id @default(uuid())
  pengirimanKapalId String
  pengirimanKapal   PengirimanKapal @relation(fields: [pengirimanKapalId], references: [id], onDelete: Cascade)
  lokasiKopdes      String
  weight            Float
  amountToPay       Float
}
